{
  "name": "pocketpig",
  "private": true,
  "version": "0.0.0",
  "description": "Mobile-first Starknet piggy bank prototype powered by StarkZap",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "node scripts/dev-all.mjs",
    "start:local": "node scripts/start-local.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server:dev": "node --experimental-specifier-resolution=node --env-file=.env --watch server/index.mjs",
    "server:start": "node --experimental-specifier-resolution=node --env-file=.env server/index.mjs"
  },
  "dependencies": {
    "@avnu/avnu-sdk": "^4.0.1",
    "@cartridge/controller": "^0.13.9",
    "@privy-io/node": "^0.10.1",
    "@privy-io/react-auth": "^3.16.0",
    "@starknet-io/get-starknet-core": "^4.0.8",
    "@supabase/supabase-js": "^2.98.0",
    "buffer": "^6.0.3",
    "ethers": "^6.15.0",
    "lucide-react": "^0.487.0",
    "moment": "^2.30.1",
    "motion": "^12.23.24",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.13.0",
    "recharts": "^2.15.2",
    "starknet": "^9.4.2",
    "starkzap": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.3.8",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
